# Credentials are normally entered in the web UI (Settings page) and stored
# in the browser's localStorage. The values below are OPTIONAL fallbacks used
# only when a request arrives without the corresponding X-GitHub-Token /
# X-Anthropic-Key header — useful for cron jobs / scripts.
# GITHUB_TOKEN=ghp_your_personal_access_token_here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

CLAUDE_MODEL=claude-opus-4-7
CONFIDENCE_THRESHOLD=0.85
WORKSPACE_DIR=./.workspace
GIT_USER_NAME=agentic-oss-contributor
GIT_USER_EMAIL=bot@agentic-oss-contributor.local

# --- GitHub OAuth (web flow) ---
# Required for the console's "Sign in with GitHub" button.
# 1. Register an OAuth App at https://github.com/settings/applications/new
#    - Homepage URL:          http://localhost:5173
#    - Authorization callback: http://localhost:8000/api/auth/github/callback
# 2. Paste the client id + secret here and restart the backend.
# GITHUB_OAUTH_CLIENT_ID=Iv1.your_client_id
# GITHUB_OAUTH_CLIENT_SECRET=your_client_secret
# GITHUB_OAUTH_SCOPE=repo read:user
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:8000
