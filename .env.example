# Credentials are normally entered in the web UI (Settings page) and stored
# in the browser's localStorage. The values below are OPTIONAL fallbacks used
# only when a request arrives without the corresponding X-GitHub-Token /
# X-Anthropic-Key header — useful for cron jobs / scripts.
# GITHUB_TOKEN=ghp_your_personal_access_token_here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

CLAUDE_MODEL=claude-opus-4-7
CONFIDENCE_THRESHOLD=0.85
WORKSPACE_DIR=./.workspace
GIT_USER_NAME=agentic-oss-contributor
GIT_USER_EMAIL=bot@agentic-oss-contributor.local
